generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ENGINEER
  ADMIN
  SUPER_ADMIN
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  PENDING_USER
  ESCALATED
  RESOLVED
  CLOSED
  REOPENED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TicketCategory {
  WINDOWS_ISSUE
  PRINTER
  NETWORK_WIFI
  EMAIL
  VPN
  SOFTWARE_INSTALL
  PERFORMANCE
  PASSWORD_RESET
  HARDWARE
  OTHER
}

enum MessageType {
  USER
  BOT
  ENGINEER
  SYSTEM
}

enum NotificationType {
  TICKET_CREATED
  TICKET_ASSIGNED
  TICKET_UPDATED
  TICKET_RESOLVED
  TICKET_ESCALATED
  SLA_BREACH
  NEW_MESSAGE
  MENTION
}

enum AssetType {
  LAPTOP
  DESKTOP
  PRINTER
  PHONE
  MONITOR
  KEYBOARD
  MOUSE
  ROUTER
  SWITCH
  OTHER
}

enum AssetStatus {
  ACTIVE
  INACTIVE
  UNDER_REPAIR
  RETIRED
  UNASSIGNED
}

model Department {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  users     User[]
  tickets   Ticket[]
}

model User {
  id               String    @id @default(uuid())
  name             String
  email            String    @unique
  mobile           String?   @unique
  password         String
  role             Role      @default(USER)
  departmentId     String?
  department       Department? @relation(fields: [departmentId], references: [id])
  avatarUrl        String?
  isActive         Boolean   @default(true)
  twoFactorEnabled Boolean   @default(false)
  twoFactorSecret  String?
  lastLoginAt      DateTime?
  lastLoginIp      String?
  passwordResetToken String?
  passwordResetExpiry DateTime?
  refreshTokens    RefreshToken[]
  createdTickets   Ticket[]   @relation("TicketCreator")
  assignedTickets  Ticket[]   @relation("TicketAssignee")
  messages         Message[]
  notifications    Notification[]
  auditLogs        AuditLog[]
  assets           Asset[]    @relation("AssetAssignee")
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([email])
  @@index([role])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

model Ticket {
  id           String         @id @default(uuid())
  ticketId     String         @unique
  title        String
  description  String
  status       TicketStatus   @default(OPEN)
  priority     Priority       @default(MEDIUM)
  category     TicketCategory @default(OTHER)
  aiResolved   Boolean        @default(false)
  aiSummary    String?
  sentiment    String?
  deviceName   String?
  ipAddress    String?
  browserInfo  String?
  osInfo       String?
  departmentId String?
  department   Department?    @relation(fields: [departmentId], references: [id])
  createdById  String
  createdBy    User           @relation("TicketCreator", fields: [createdById], references: [id])
  assignedToId String?
  assignedTo   User?          @relation("TicketAssignee", fields: [assignedToId], references: [id])
  resolvedAt   DateTime?
  closedAt     DateTime?
  slaDeadline  DateTime?
  slaBreach    Boolean        @default(false)
  tags         String[]
  messages     Message[]
  attachments  Attachment[]
  history      TicketHistory[]
  notifications Notification[]
  relatedAssetId String?
  relatedAsset   Asset?       @relation(fields: [relatedAssetId], references: [id])
  duplicateOf  String?
  reopenCount  Int            @default(0)
  internalNotes InternalNote[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([ticketId])
  @@index([status])
  @@index([priority])
  @@index([createdById])
  @@index([assignedToId])
  @@index([createdAt])
}

model Message {
  id          String      @id @default(uuid())
  ticketId    String
  ticket      Ticket      @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  content     String
  type        MessageType
  senderId    String?
  sender      User?       @relation(fields: [senderId], references: [id])
  isRead      Boolean     @default(false)
  metadata    Json?
  createdAt   DateTime    @default(now())

  @@index([ticketId])
  @@index([senderId])
  @@index([createdAt])
}

model InternalNote {
  id        String   @id @default(uuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  content   String
  authorId  String
  createdAt DateTime @default(now())

  @@index([ticketId])
}

model Attachment {
  id         String   @id @default(uuid())
  ticketId   String
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  fileName   String
  fileType   String
  fileSize   Int
  filePath   String
  uploadedBy String
  createdAt  DateTime @default(now())

  @@index([ticketId])
}

model TicketHistory {
  id        String   @id @default(uuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  field     String
  oldValue  String?
  newValue  String?
  changedBy String
  createdAt DateTime @default(now())

  @@index([ticketId])
}

model KnowledgeBase {
  id          String   @id @default(uuid())
  title       String
  content     String
  category    TicketCategory @default(OTHER)
  tags        String[]
  views       Int      @default(0)
  helpful     Int      @default(0)
  notHelpful  Int      @default(0)
  isPublished Boolean  @default(true)
  createdById String
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([isPublished])
}

model Asset {
  id           String      @id @default(uuid())
  name         String
  type         AssetType
  serialNumber String?     @unique
  model        String?
  manufacturer String?
  purchaseDate DateTime?
  warrantyExpiry DateTime?
  status       AssetStatus @default(UNASSIGNED)
  assignedToId String?
  assignedTo   User?       @relation("AssetAssignee", fields: [assignedToId], references: [id])
  location     String?
  notes        String?
  tickets      Ticket[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([type])
  @@index([status])
  @@index([assignedToId])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  ticketId  String?
  ticket    Ticket?          @relation(fields: [ticketId], references: [id])
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  resource  String
  resourceId String?
  details   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([resource])
  @@index([createdAt])
}

model SLAConfig {
  id             String   @id @default(uuid())
  priority       Priority @unique
  responseTime   Int      // minutes
  resolutionTime Int      // minutes
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model QuickReplyTemplate {
  id        String   @id @default(uuid())
  title     String
  content   String
  category  TicketCategory?
  createdBy String
  isGlobal  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmailTemplate {
  id        String   @id @default(uuid())
  name      String   @unique
  subject   String
  body      String
  variables String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
