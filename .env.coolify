# ============================================
# Copy this into Coolify's Environment Variables
# section when creating the deployment.
# DO NOT commit a filled .env to git.
# ============================================

# ── PostgreSQL ──────────────────────────────
POSTGRES_USER=itsupport
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=itsupport_db

# ── Database URL (internal Docker network) ──
DATABASE_URL=postgresql://itsupport:CHANGE_ME_STRONG_PASSWORD@postgres:5432/itsupport_db

# ── Redis ────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379

# ── JWT (generate random 64-char strings) ───
JWT_SECRET=CHANGE_ME_JWT_SECRET_MIN_64_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_JWT_REFRESH_SECRET_MIN_64_CHARS
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── App URLs (replace with your domain/IP) ──
FRONTEND_URL=http://YOUR_SERVER_IP_OR_DOMAIN
CORS_ORIGINS=http://YOUR_SERVER_IP_OR_DOMAIN
NEXT_PUBLIC_API_URL=http://YOUR_SERVER_IP_OR_DOMAIN/api
NEXT_PUBLIC_SOCKET_URL=http://YOUR_SERVER_IP_OR_DOMAIN

# ── OpenAI (optional) ────────────────────────
OPENAI_API_KEY=

# ── SMTP Email (optional) ────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=IT Support <noreply@company.com>

# ── Port ─────────────────────────────────────
HTTP_PORT=80
